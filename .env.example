# ── Resend ───────────────────────────────────────────────────────────────
# Your Resend API key (starts with "re_"). Get it at https://resend.com/api-keys
RESEND_API_KEY=

# The address you send FROM. Must be on your VERIFIED Resend domain.
FROM_EMAIL=you@yourdomain.com
# Display name shown in the inbox. A real name lifts cold-email open rates.
FROM_NAME=Your Name
# Where replies go (can be a normal inbox, e.g. Gmail).
REPLY_TO=you@yourdomain.com

# ── Cold-email compliance (CAN-SPAM requires a real postal address) ────────
PHYSICAL_ADDRESS=Your Company, 123 Main St, City, Country
UNSUBSCRIBE_MAILTO=unsubscribe@yourdomain.com

# ── Your offer (fed to the model when writing each email) ──────────────────
SENDER_COMPANY=Your Company
OFFER=we build fast websites for local businesses
CTA_GOAL=a quick 15-minute call this week

# ── DeepSeek (email generation) ────────────────────────────────────────────
# API key from https://platform.deepseek.com/api_keys (starts with "sk-").
DEEPSEEK_API_KEY=
# Model id. "deepseek-chat" is the general chat model; check the DeepSeek docs
# for the current name of the flash/V-series model you want and set it here.
DEEPSEEK_MODEL=deepseek-chat
# Base URL. Use https://api.deepseek.com (OpenAI-compatible). Rarely changed.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Sending safety ─────────────────────────────────────────────────────────
DAILY_CAP=30
# When TEST_MODE=true, every send is redirected to TEST_INBOX instead of the
# real business. Great while you verify things. Set to false to go live.
TEST_MODE=true
TEST_INBOX=you@yourdomain.com

# ── Local server ───────────────────────────────────────────────────────────
PORT=4820
# Shared secret the extension must send to push leads. Any random string.
# Run `npm run setup` to generate one automatically.
OUTREACH_TOKEN=

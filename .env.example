# ── Resend ───────────────────────────────────────────────────────────────
# Your Resend API key (starts with "re_"). Get it at https://resend.com/api-keys
RESEND_API_KEY=

# The address you send FROM. Must be on your VERIFIED Resend domain.
FROM_EMAIL=you@yourdomain.com
# Display name shown in the inbox. A real name lifts cold-email open rates.
FROM_NAME=Your Name
# Where replies go (can be a normal inbox, e.g. Gmail).
REPLY_TO=you@yourdomain.com

# ── Cold-email compliance (CAN-SPAM requires a real postal address) ────────
PHYSICAL_ADDRESS=Your Company, 123 Main St, City, Country
UNSUBSCRIBE_MAILTO=unsubscribe@yourdomain.com

# ── Your offer (fed to the model when writing each email) ──────────────────
SENDER_COMPANY=Your Company
OFFER=we build fast websites for local businesses
CTA_GOAL=a quick 15-minute call this week

# ── DeepSeek (email generation) ────────────────────────────────────────────
# API key from https://platform.deepseek.com/api_keys (starts with "sk-").
DEEPSEEK_API_KEY=
# Model id. "deepseek-chat" is the general chat model; check the DeepSeek docs
# for the current name of the flash/V-series model you want and set it here.
DEEPSEEK_MODEL=deepseek-chat
# Base URL. Use https://api.deepseek.com (OpenAI-compatible). Rarely changed.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Sending safety ─────────────────────────────────────────────────────────
DAILY_CAP=30
# When TEST_MODE=true, every send is redirected to TEST_INBOX instead of the
# real business. Great while you verify things. Set to false to go live.
TEST_MODE=true
TEST_INBOX=you@yourdomain.com

# ── Stripe subscriptions (optional until you launch billing) ───────────────
# Secret key from https://dashboard.stripe.com/apikeys (sk_live_... / sk_test_...)
STRIPE_SECRET_KEY=
# Signing secret for the webhook endpoint /api/stripe/webhook (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Price IDs of your recurring products (price_...): Pro and Ultra tiers.
STRIPE_PRICE_PRO=
STRIPE_PRICE_ULTRA=

# ── Server / deployment ────────────────────────────────────────────────────
PORT=4820
# Set NODE_ENV=production on the VPS. It makes the server bind 0.0.0.0 (so the
# reverse proxy can reach it) and marks the session cookie Secure (HTTPS only).
NODE_ENV=

# Bind address. Leave blank — it's chosen automatically (0.0.0.0 in production,
# 127.0.0.1 locally). Only set this to override.
HOST=

# Public URL of the deployed site, e.g. https://kumora.io. Used for the banner
# and absolute links. Leave blank for local dev.
PUBLIC_URL=

# Where the SQLite database lives. On the VPS point this at a MOUNTED VOLUME so
# data survives redeploys. The Docker image defaults DATA_DIR=/app/data and
# declares a volume there. Leave blank locally (defaults to ./data).
DATA_DIR=
# Optional: override the full DB file path directly instead of DATA_DIR/app.db.
SQLITE_PATH=
